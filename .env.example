# ── DATABASE ─────────────────────────────────────────────────────────
# Use o docker-compose pra subir o Postgres local: `docker compose up -d`
DATABASE_URL="postgresql://marshfit:marshfit@localhost:5432/marshfit?schema=public"

# ── API ──────────────────────────────────────────────────────────────
API_PORT=3334
API_HOST=0.0.0.0
NODE_ENV=development

# ── AUTH ─────────────────────────────────────────────────────────────
JWT_SECRET="troque-em-producao-com-string-longa-aleatoria-de-pelo-menos-32-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:5174,http://localhost:5175"

# ── STORAGE (S3-compatible, opcional em dev) ─────────────────────────
STORAGE_MODE=local
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── PORTAL ───────────────────────────────────────────────────────────
PORTAL_URL="http://localhost:5174"
LANDING_URL="http://localhost:5175"

# ── LANDING (Vite, lidas pelo apps/landing) ──────────────────────────
# Em dev local, deixe como abaixo. Em produção, aponte para a URL pública.
VITE_API_URL="http://localhost:3334"
VITE_PORTAL_URL="http://localhost:5174"
